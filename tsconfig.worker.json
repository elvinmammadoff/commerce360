{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "incremental": false,
    "plugins": []
  },
  "include": ["src/worker/**/*.ts"],
  "exclude": ["node_modules", "src/app", "src/components", "src/hooks"]
}
